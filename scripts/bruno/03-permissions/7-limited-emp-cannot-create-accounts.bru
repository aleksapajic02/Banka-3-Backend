meta {
  name: 9-Limited Emp CANNOT Create Accounts
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/accounts
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{limitedEmpToken}}
}

body:json {
  {
    "client_id": 1,
    "account_type": "TEKUCI",
    "subtype": "licni",
    "currency": "RSD",
    "initial_balance": 1000
  }
}

tests {
  test("status 403", function() {
    expect(res.status).to.equal(403);
  });
}
